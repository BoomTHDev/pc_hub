generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum UserPosition {
  CUSTOMER
  EMPLOYEE
  ADMIN
}

enum CategoryStatus {
  ACTIVE
  INACTIVE
}

model User {
  id        Int          @id @default(autoincrement())
  firstName String
  lastName  String
  position  UserPosition @default(CUSTOMER)
  email     String       @unique
  password  String
  phone     String       @unique
  createdAt DateTime     @default(now())
}

model Category {
  id          Int            @id @default(autoincrement())
  name        String
  description String? // Can null value
  status      CategoryStatus @default(ACTIVE)
}
